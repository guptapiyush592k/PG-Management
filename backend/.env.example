# Required
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pg_management_database
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional
APP_NAME=PG Management API
APP_ENV=development
DEBUG=true
DEMO_TENANT_SLUG=demo

# Optional: override sync URL for Alembic (defaults to DATABASE_URL with psycopg driver)
# DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/pg_management

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Storage (local | s3)
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads
LOCAL_STORAGE_PUBLIC_BASE_URL=http://localhost:8000
STORAGE_PRESIGNED_URL_EXPIRES_SECONDS=3600
# Optional: separate HMAC key for local presigned file URLs (defaults to JWT_SECRET_KEY)
# STORAGE_SIGNING_KEY=
MAX_UPLOAD_BYTES=10485760

# Auth rate limiting
AUTH_RATE_LIMIT_MAX_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# S3-compatible storage (required when STORAGE_PROVIDER=s3)
# S3_BUCKET_NAME=
# S3_REGION=
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
