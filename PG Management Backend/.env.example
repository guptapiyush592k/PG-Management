# Required
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pg_management
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional
APP_NAME=PG Management API
APP_ENV=development
DEBUG=true
DEMO_TENANT_SLUG=demo

# Optional: override sync URL for Alembic (defaults to DATABASE_URL with psycopg driver)
# DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/pg_management

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
